---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Menu" description="Explore our epic organic menu.">
	<div class="page-header bg-dark text-center" style="padding: 4rem 0 2rem;">
		<div class="container">
			<h1 class="text-h1 mb-2">Our Menu</h1>
			<p class="text-lead" style="color: var(--color-text-light);">Scroll through our digital flipbook below.</p>
		</div>
	</div>

	<div class="container section">
		<div class="menu-container mb-8" style="width:100%; height:80vh; max-height:800px; border-radius: var(--radius-lg); overflow:hidden; box-shadow: var(--shadow-lg);">
			<!-- Embed the actual external menu flipbook -->
			<iframe 
				src="https://kapikapichirripo.com/menu-english-espanol/#flipbook-df_986/1/" 
				width="100%" 
				height="100%" 
				style="border:none;" 
				title="Kapi Kapi Menu"
                allowfullscreen>
			</iframe>
		</div>
		
		<div class="text-center mt-8">
		  <a href="https://kapikapichirripo.com/grocery-order-form/" target="_blank" class="btn btn-primary">Order For Pickup</a>
		</div>
	</div>
</Layout>

<style>
	.page-header {
		padding: 6rem 0 4rem;
	}
</style>
