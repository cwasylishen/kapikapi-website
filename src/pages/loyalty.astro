---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Loyalty Program" description="Join the Kapi Kapi Loyalty Program.">
	<div class="page-header bg-dark text-center">
		<div class="container">
			<h1 class="text-h1 mb-2">Loyalty Program</h1>
			<p class="text-lead" style="color: var(--color-text-light);">Earn rewards for nourishing your body.</p>
		</div>
	</div>

	<div class="container section">
		<div class="loyalty-content text-center mb-8" style="max-width: 800px; margin-left: auto; margin-right: auto;">
			<h2 class="text-h2 mb-4">Join Our Community</h2>
			<p class="text-body mb-4">
				We appreciate our local community and regular visitors. That's why we've created a loyalty program to give back to those who support our mission of providing healthy, organic, and sustainable food.
			</p>
			
			<div class="grid-3 mt-8 text-left">
				<div class="card p-4">
					<div class="icon-wrap mb-2" style="background: var(--color-bg-secondary); padding: 1rem; border-radius: 50%; display: inline-block;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
					</div>
					<h3 class="text-h4 mb-2">Shop & Earn</h3>
					<p class="text-body text-muted">Earn points on every purchase made in our organic grocery store or restaurant.</p>
				</div>
				<div class="card p-4">
					<div class="icon-wrap mb-2" style="background: var(--color-bg-secondary); padding: 1rem; border-radius: 50%; display: inline-block;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22.5 12 18.5 4 22.5 4 12"></polyline><rect x="4" y="2" width="16" height="10"></rect></svg>
					</div>
					<h3 class="text-h4 mb-2">Redeem Rewards</h3>
					<p class="text-body text-muted">Use your points for discounts, free elixirs, or special organic items.</p>
				</div>
				<div class="card p-4">
					<div class="icon-wrap mb-2" style="background: var(--color-bg-secondary); padding: 1rem; border-radius: 50%; display: inline-block;">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
					</div>
					<h3 class="text-h4 mb-2">Exclusive Perks</h3>
					<p class="text-body text-muted">Get early access to community events and special promotions.</p>
				</div>
			</div>
			
			<div class="mt-8">
				<p class="text-h4 mb-4">Ask about joining during your next visit!</p>
				<a href="/contact" class="btn btn-primary">Contact Us for Details</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.page-header {
		padding: 6rem 0 4rem;
	}
	.p-4 { padding: 1.5rem; }
</style>
